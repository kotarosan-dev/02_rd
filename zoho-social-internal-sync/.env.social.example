# Zoho Social 内部 API 認証情報テンプレート
# 取得手順:
#   1) ブラウザで https://social.zoho.com/<portal>/home を開く
#   2) F12 → Network → 任意の /api/* リクエストをクリック
#   3) Headers タブから以下をコピー
#
# ⚠️ このファイルをコピーして .env.social として保存（.gitignore 済み）
# ⚠️ 自社 Portal 専用。クライアント Portal や他人 Cookie での使用禁止。

# 通常 https://social.zoho.com（日本DCの場合は social.zoho.jp / .eu / .in 等）
ZOHO_SOCIAL_BASE_URL=https://social.zoho.com

# URL の /<portal>/ 部分（数値ID）
# 例: https://social.zoho.com/12345678/home → 12345678
ZOHO_SOCIAL_PORTAL_ID=

# ブランド ID（HAR 内 X-Brand-Id ヘッダ または URL パラメータ brandId=）
ZOHO_SOCIAL_BRAND_ID=

# LinkedIn Channel ID（HAR の channelId= / networkId= から）
# MVP は LINKEDIN_PERSONAL（個人プロフィール）で進める。
# 会社ページに切り替える際は LINKEDIN_COMPANY 用の Channel ID を別途取得する。
ZOHO_SOCIAL_CHANNEL_TYPE=LINKEDIN_PERSONAL
ZOHO_SOCIAL_CHANNEL_ID_LINKEDIN_PERSONAL=
ZOHO_SOCIAL_CHANNEL_ID_LINKEDIN_COMPANY=

# Headers > Request Headers > Cookie の値全文
ZOHO_SOCIAL_COOKIE=

# Headers > Request Headers > X-ZCSRF-TOKEN の値
# Books と同様、Cookie 内の zsocial_csr_param= 等の値と対応する見込み
# HAR 解析後に正しいキー名を docs/social-internal-api-spec.md に記載する
ZOHO_SOCIAL_CSRF_TOKEN=

# 任意（HAR より既知の値をデフォルトに）
ZOHO_SOCIAL_USER_AGENT=

# メディアアップロード用 spaceId
# HAR の AttachmentUpload.do リクエストの spaceId フィールドから取得
# 例: 90000791817
ZOHO_SOCIAL_SPACE_ID=
