# dotenvx 経由で暗号化推奨。下記は値の形式メモ。

# zohocrm.dev の Web セッション Cookie 全文
# DevTools > Network > 任意のリクエスト > Headers > cookie をそのままコピー
SLYTEUI_COOKIE="JSESSIONID=...; _zcsr_tmp=...; ..."

# ベース URL（DC により切替）
SLYTEUI_BASE_URL="https://www.zohocrm.dev"

# Referer。Zoho 系はこれが無いと弾かれることがある
SLYTEUI_REFERER="https://www.zohocrm.dev/explore/slyteui"

# CSRF/Org が必要だと判明したら追加
# SLYTEUI_CSRF_TOKEN=""
# SLYTEUI_ORG_ID=""

# HAR 解析で見つかった追加ヘッダを JSON で（任意）
# 例: '{"X-ZCSRF-TOKEN":"xxx","X-Source":"docs"}'
SLYTEUI_EXTRA_HEADERS=""

# 同時取得数（API 過負荷を避ける）
SLYTEUI_CONCURRENCY="3"

# リクエスト間ウェイト ms
SLYTEUI_REQUEST_DELAY_MS="200"
