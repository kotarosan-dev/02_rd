# 全部 dotenvx 経由で暗号化する想定。下記は値の形式メモ。

# Cookie ヘッダ全文（DevTools の Request Headers > cookie をそのままコピー）
ZOHO_COOKIE="zalb_xxx=...; JSESSIONID=...; _zcsr_tmp=...; crmcsr=...; ..."

# X-ZCSRF-TOKEN ヘッダ値。"crmcsrfparam=<token>" 形式。<token> は Cookie の _zcsr_tmp と同値
ZOHO_CSRF_TOKEN="crmcsrfparam=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# X-CRM-ORG ヘッダ値。数値の Zoho Org ID
ZOHO_ORG_ID="90000792316"

# 例: https://crm.zoho.jp / https://crm.zoho.com / https://crm.zoho.eu など、自分のデータセンター
ZOHO_BASE_URL="https://crm.zoho.jp"

# 本番書き込み許可フラグ。デフォルト 0。1 のときだけ書き込み実行
ZOHO_ALLOW_PROD_WRITE="0"
