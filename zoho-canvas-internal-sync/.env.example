# Zoho CRM 内部API用セッション情報
# ブラウザで crm.zoho.jp にログイン → DevTools → Network → 任意のXHRリクエストから取得する。
# Cookie / CSRF はセッション期限で失効するので、失敗時は再採取する。

# 全Cookieをセミコロン区切りで（DevToolsの "Request Headers > Cookie" をそのまま貼る）
ZOHO_CRM_COOKIE=

# crmcsr または CSRF_TOKEN の値（同一）
ZOHO_CRM_CSRF=

# X-CRM-ORG ヘッダ用の組織ID
ZOHO_CRM_ORG_ID=

# 接続先（既定: 日本DC）
ZOHO_CRM_BASE=https://crm.zoho.jp
