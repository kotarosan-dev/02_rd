{
  "name": "zoho-canvas-internal-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Zoho CRM Canvas views (HomeView/ListView/DetailView) を OAuth + 内部APIで管理し、クローン/クロスOrgデプロイ/デザイン起点生成を行うツール群。",
  "scripts": {
    "list": "node scripts/list.mjs",
