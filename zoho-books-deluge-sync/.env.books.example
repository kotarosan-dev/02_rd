# Zoho Books 内部 API 認証情報（自社 Org 専用）
#
# 取得手順:
#   1) https://books.zoho.jp/app/<org>/integrations/customfunctions を開く
#   2) F12 → Network → 任意の /api/v3/integrations/... リクエストをクリック
#   3) Headers > Request Headers から:
#      - Cookie の値全文 → ZOHO_BOOKS_COOKIE
#      - X-ZCSRF-TOKEN の値 → ZOHO_BOOKS_CSRF_TOKEN（"zbcsparam=..." 形式）
#
# ⚠️ このファイルを .env.books としてコピーし、絶対に commit しない。

ZOHO_BOOKS_BASE_URL=https://books.zoho.jp
ZOHO_BOOKS_ORG_ID=90000792806

ZOHO_BOOKS_COOKIE=
ZOHO_BOOKS_CSRF_TOKEN=zbcsparam=

# 任意（HAR 観察値のデフォルト）
ZOHO_BOOKS_SOURCE=zbclient
ZOHO_BOOKS_ROLE_ID=3092000000000837
ZOHO_BOOKS_ASSET_VERSION=Apr_18_2026_23910

# 本番書き込みガード（push/create/delete を実行するときだけ "1" にセット）
ZOHO_BOOKS_ALLOW_PROD_WRITE=
