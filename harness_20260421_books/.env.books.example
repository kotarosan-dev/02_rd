# Books 内部 API 認証情報テンプレート
# 取得手順:
#   1) ブラウザで https://books.zoho.jp/app/90000792806/integrations/customfunctions を開く
#   2) F12 → Network → 任意の /api/v3/integrations/customfunctions リクエストをクリック
#   3) Headers タブから以下をコピー
#
# ⚠️ このファイルをコピーして .env.books として保存（.gitignore 済み）

ZOHO_BOOKS_BASE_URL=https://books.zoho.jp
ZOHO_BOOKS_ORG_ID=90000792806

# Headers > Request Headers > Cookie の値全文（"_zcsr_tmp=...; iamcsr=...; ..." の形）
ZOHO_BOOKS_COOKIE=

# Headers > Request Headers > X-ZCSRF-TOKEN の値（"zbcsparam=..." 形式）
# 値は Cookie 内の zbcscook= の値と完全一致する（138 文字）。
# Cookie 採取後、その中の zbcscook= の値を見つけて、頭に "zbcsparam=" を付けて入れる。
ZOHO_BOOKS_CSRF_TOKEN=zbcsparam=<zbcscook の値をここに貼り付け>

# 任意（HAR より既知の値をデフォルト）
ZOHO_BOOKS_SOURCE=zbclient
ZOHO_BOOKS_ROLE_ID=3092000000000837
ZOHO_BOOKS_ASSET_VERSION=Apr_18_2026_23910
